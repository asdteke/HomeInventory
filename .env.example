# Home Inventory - Example environment variables
# Do not put real secrets in this file.

# Runtime
NODE_ENV=production
PORT=3001
SITE_URL=https://your-domain.com

# Optional runtime secret provider
# Set SECRET_PROVIDER=oci on OCI compute instances to load selected secrets from
# OCI Secret Management before the app starts. Leave as env for local/dev.
SECRET_PROVIDER=env
# OCI_AUTH_MODE=instance_principal
# OCI_REGION=eu-frankfurt-1
# OCI_VAULT_ID=ocid1.vault.oc1..exampleuniqueID
# OCI_SECRET_MAPPINGS={"JWT_SECRET":"homeinventory-jwt-secret","APP_ENCRYPTION_KEY":"homeinventory-app-encryption-key","APP_ENCRYPTION_KEY_ID":"homeinventory-app-encryption-key-id","RESEND_API_KEY":"homeinventory-resend-api-key"}
# OCI_SECRET_OVERWRITE=false
# OCI_SECRET_BUNDLE_STAGE=CURRENT

# Auth / Security
JWT_SECRET=replace-with-a-long-random-secret
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-or-64-char-hex-key
APP_ENCRYPTION_KEY_ID=2026-03-primary
# Optional key rotation support: JSON object of legacy key ids to keys
# APP_ENCRYPTION_KEYRING={"2025-12-primary":"old-base64-or-hex-key"}
EXPOSE_SERVER_INFO=false

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email provider
RESEND_API_KEY=your-resend-api-key
SUPPORT_EMAIL=support@example.com
# Optional: language code used for all outgoing emails (must match one of client/public/locales/*, e.g. en, tr, es, zh-Hans)
APP_EMAIL_LANGUAGE=en

# Optional bootstrap/admin setup
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# IndexNow (SEO rapid indexing)
INDEXNOW_KEY=your-indexnow-key
INDEXNOW_BASE_URL=https://your-domain.com
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
# Optional explicit key location override
# INDEXNOW_KEY_LOCATION=https://your-domain.com/your-indexnow-key.txt

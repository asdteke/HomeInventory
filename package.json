{
  "name": "home-inventory",
  "version": "1.0.0",
  "description": "Ev Envanter Sistemi - Home Inventory Management System",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server.js",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server.js",
    "install-all": "npm install && cd client && npm install",
    "indexnow:submit": "node -r dotenv/config scripts/indexnow-submit.mjs"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.6.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "i18next": "^25.7.4",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "npmlog": "^7.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
